{
  "name": "ksp-crime-intelligence-backend",
  "description": "FastAPI backend for Crime Intelligence Platform",
  "runtime": "python:3.11",
  "entrypoint": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "buildCommand": "pip install -r requirements.txt",
  "port": 8000,
  "env": {
    "PYTHONUNBUFFERED": "1",
    "DEBUG": "false"
  },
  "healthCheck": {
    "path": "/health",
    "interval": 30,
    "timeout": 5
  },
  "resources": {
    "cpu": "2",
    "memory": "4Gi"
  },
  "scaling": {
    "minInstances": 2,
    "maxInstances": 10,
    "targetCPU": 70
  },
  "environment": "production"
}
