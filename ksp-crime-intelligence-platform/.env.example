# Catalyst Configuration
CATALYST_API_KEY=your_catalyst_api_key_here
CATALYST_ENVIRONMENT=development
CATALYST_REGION=default
CATALYST_PROJECT_ID=your_catalyst_project_id

# Backend API Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000
DEBUG=true

# Database Configuration
DATASTORE_CONNECTION_STRING=postgresql://user:password@localhost:5432/crime_platform
CACHE_TTL=3600
GRAPH_DB_URI=neo4j://localhost:7687

# Authentication
AUTH_SECRET_KEY=your_secret_key_here
AUTH_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services Configuration
CONVOKRAFT_API_KEY=your_convokraft_key
ZIA_API_KEY=your_zia_key
QUICKML_PROJECT_ID=your_quickml_project_id

# File Storage (Stratus)
STRATUS_BUCKET=crime-intelligence-evidence
MAX_FILE_SIZE=104857600

# Analytics Configuration
HOTSPOT_ANALYSIS_RADIUS_KM=5
ANOMALY_THRESHOLD=0.85
RISK_SCORE_MODEL_VERSION=1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email Configuration (for reports/alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Redis Configuration (for caching/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Feature Flags
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_LINK_ANALYSIS=true
ENABLE_CONVERSATIONAL_AI=true
